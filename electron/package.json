{
  "name": "drifter-electron",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "package": "electron-builder"
  },
  "dependencies": {
    "electron": "^28.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.drifter.app",
    "productName": "Drifter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "../frontend/dist/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
